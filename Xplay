  NS.extractAllLocators = function(){
    const prevDoc = getPreviewDoc();
    if(!prevDoc || !prevDoc.body) { toast('Preview not ready', 'error'); return; }
    const els = collectCandidateElements(prevDoc);
    NS.CURRENT_LOCATORS = els.map(el => buildLocatorObject(el));
    renderLocatorList();
    toast(`Extracted ${NS.CURRENT_LOCATORS.length} elements`, 'success');
  };

  function getPreviewDoc(){
    const f = NS.$('#preview');
    if(f && f.tagName && f.tagName.toLowerCase() === 'iframe'){
      try { if(f.contentDocument && f.contentDocument.body) return f.contentDocument; } catch(e){}
    }
    return window._PARSER_DOC || document;
  }

  NS.renderPreviewFromPaste = function(){
    const ta = NS.$('#pasteBox');
    if(!ta){ toast('Input not found', 'error'); return; }
    const html = ta.value || '';
    if(!html.trim()) { toast('Paste HTML first', 'error'); return; }

    NS.CURRENT_HTML = html;
    const prev = NS.$('#preview');
    if(prev && prev.tagName && prev.tagName.toLowerCase() === 'iframe'){
      let src = html || '<!doctype html><body><h3>No content</h3></body>';
      try{ src = src.replace(/<script[\s\S]*?>[\s\S]*?<\/script>/gi, ''); }catch(e){}
      try { prev.srcdoc = src; } catch(e){ toast('Preview failed', 'error'); return; }
      try { window._PARSER_DOC = (new DOMParser()).parseFromString(html,'text/html'); } catch(e){}
      
      const loadHandler = () => { NS.extractAllLocators(); };
      prev.addEventListener('load', loadHandler, { once: true });
      setTimeout(loadHandler, 500);
      toast('Preview rendered', 'success');
    }
  };

  function generatePlaywrightCode(){
    const selected = getSelectedLocators();
    if(!selected.length) { toast('Select elements first', 'error'); return; }

    const code = [
      "import { test, expect } from '@playwright/test';",
      "",
      "test('Generated test', async ({ page }) => {",
      "  await page.goto('https://example.com');",
      "",
    ];

    selected.forEach(elObj => {
      const best = Object.values(elObj.playwright).find(x => x && x.includes('page.getByRole'));
      const loc = best || Object.values(elObj.playwright).find(x => x);
      if(loc){
        code.push(`  // ${elObj.text || elObj.tag}`);
        code.push(`  const ${elObj.name} = ${loc};`);
        code.push(`  await ${elObj.name}.click();`);
        code.push("");
      }
    });

    code.push("});");
    const out = NS.$('#output');
    if(out) out.value = code.join('\n');
    toast('Code generated', 'success');
  }

  function getSelectedLocators(){
    const cont = NS.$('#locator-list');
    if(!cont) return [];
    const checks = Array.from(cont.querySelectorAll('.elem-check:checked'));
    return checks.map(cb => {
      const uid = cb.dataset.uid;
      return NS.CURRENT_LOCATORS.find(x => x._uid === uid);
    }).filter(Boolean);
  }

  function downloadFile(name, content){
    const blob = new Blob([content], { type: 'text/plain' });
    const a = document.createElement('a');
