  function fileToBase64(file){
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = e => {
        const dataUrl = e.target.result;
        const base64 = dataUrl.split(',')[1];
        resolve({ base64, mimeType: file.type || 'image/png' });
      };
      reader.onerror = reject;
      reader.readAsDataURL(file);
    });
  }

  function buildAnalysisPrompt(){
    const focusButtons = document.getElementById('optButtons')?.checked;
    const focusInputs = document.getElementById('optInputs')?.checked;
    const focusLinks = document.getElementById('optLinks')?.checked;
    const focusAll = document.getElementById('optAll')?.checked;

    const targets = [];
    if(focusAll || (!focusButtons && !focusInputs && !focusLinks)){
      targets.push('all interactive and visible UI elements');
    } else {
      if(focusButtons) targets.push('buttons and clickable actions');
      if(focusInputs) targets.push('input fields, text areas, dropdowns, checkboxes, radio buttons, forms');
      if(focusLinks) targets.push('links and navigation items');
    }

    return `You are an expert frontend developer analyzing a UI screenshot to extract locators for automated testing with Playwright.

Analyze this screenshot and identify all ${targets.join(', ')}.

For each element found, return a JSON array. Each element must be an object with these exact fields:
- "tag": HTML tag name (e.g. "button", "input", "a", "select", "textarea")
- "type": input type if applicable (e.g. "text", "email", "password", "checkbox", "submit", null)
- "text": visible text label or button text (empty string if none)
- "placeholder": placeholder text if it's an input (null if none)
- "id": a suggested id attribute value (use the visible label/text to infer, e.g. "email-input", "login-btn"; null if not obvious)
- "ariaLabel": a suitable aria-label based on what you see (e.g. "Submit form", "Search")
- "role": ARIA role (e.g. "button", "textbox", "link", "checkbox", "combobox")
- "dataTestId": a suggested data-testid value (kebab-case, e.g. "login-button", "email-field"; null if not obvious)
- "description": short description of where it appears and what it does

Return ONLY a valid JSON array. No markdown fences, no explanation, just the raw JSON array.`;
  }

  async function analyzeImage(){
    if(!IMG_BASE64){ toast('Upload an image first', 'error'); return; }

    const statusEl = document.getElementById('aiStatus');
    const statusText = document.getElementById('aiStatusText');
    const analyzeBtn = document.getElementById('btnAnalyzeImage');
    const resultsWrap = document.getElementById('imgResultsWrap');

    if(statusEl) statusEl.classList.remove('hidden');
    if(statusText) statusText.textContent = 'Sending to Claude AI…';
    if(analyzeBtn){ analyzeBtn.disabled = true; analyzeBtn.textContent = '⏳ Analyzing…'; }
    if(resultsWrap) resultsWrap.classList.add('hidden');

    try {
      const prompt = buildAnalysisPrompt();
      const response = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 2000,
          messages: [{
            role: 'user',
            content: [
              { type: 'image', source: { type: 'base64', media_type: IMG_MIME, data: IMG_BASE64 } },
              { type: 'text', text: prompt }
            ]
          }]
        })
      });

      const data = await response.json();
      if(!response.ok){ throw new Error(data.error?.message || 'API error'); }

      const rawText = (data.content || []).map(c => c.type === 'text' ? c.text : '').join('');
      if(statusText) statusText.textContent = 'Parsing results…';

      let elements = [];
      try {
        const clean = rawText.replace(/```json|```/g, '').trim();
        elements = JSON.parse(clean);
        if(!Array.isArray(elements)) throw new Error('Not an array');
      } catch(e){
        // Try to extract JSON array from text
        const match = rawText.match(/\[[\s\S]*\]/);
        if(match){ try { elements = JSON.parse(match[0]); } catch(e2){ throw new Error('Could not parse AI response'); } }
        else { throw new Error('Could not parse AI response as JSON'); }
      }

      IMG_EXTRACTED = elements.map(el => buildLocatorObjectFromAI(el));
      renderImageResults(elements);
      if(statusEl) statusEl.classList.add('hidden');
      if(resultsWrap) resultsWrap.classList.remove('hidden');
      toast(`Found ${elements.length} elements`, 'success');

    } catch(err){
      console.error('Image analysis error:', err);
      toast('Analysis failed: ' + err.message, 'error');
      if(statusEl) statusEl.classList.add('hidden');
    } finally {
      if(analyzeBtn){ analyzeBtn.disabled = false; analyzeBtn.textContent = '🔍 Analyze with Claude AI'; }
    }
  }

  function buildLocatorObjectFromAI(el){
    const tag = el.tag || 'div';
    const id = el.id || null;
    const dataTestId = el.dataTestId || null;
    const ariaLabel = el.ariaLabel || el.text || null;
    const placeholder = el.placeholder || null;
    const role = el.role || el.tag || 'generic';
    const text = el.text || '';
    const type = el.type || null;

    const playwright = {};

    // getByRole
    if(role && ariaLabel){
      playwright.getByRole = `page.getByRole('${role}', { name: '${(ariaLabel).replace(/'/g,"\\'")}' })`;
    } else if(role){
      playwright.getByRole = `page.getByRole('${role}')`;
    }

    // getByTestId
    if(dataTestId){ playwright.getByTestId = `page.getByTestId('${dataTestId}')`; }

    // getByLabel
    if(ariaLabel){ playwright.getByLabel = `page.getByLabel('${ariaLabel.replace(/'/g,"\\'")}')` ; }

    // getByPlaceholder
    if(placeholder){ playwright.getByPlaceholder = `page.getByPlaceholder('${placeholder.replace(/'/g,"\\'")}')` ; }

    // getByText
    if(text && ['button','a','span','div'].includes(tag)){
      playwright.getByText = `page.getByText('${text.replace(/'/g,"\\'")}')`;
    }

    // CSS
    if(id){ playwright.css = `page.locator('#${id}')` ; }
    else if(dataTestId){ playwright.css = `page.locator('[data-testid="${dataTestId}"]')` ; }

    // XPath
    const xpathParts = [];
    if(id) xpathParts.push(`//${tag}[@id="${id}"]`);
    if(dataTestId) xpathParts.push(`//${tag}[@data-testid="${dataTestId}"]`);
    if(ariaLabel) xpathParts.push(`//${tag}[@aria-label="${ariaLabel}"]`);
    if(placeholder) xpathParts.push(`//${tag}[@placeholder="${placeholder}"]`);
    if(text) xpathParts.push(`//${tag}[normalize-space(.)="${text}"]`);
    xpathParts.push(`//${tag}`);

    playwright.xpath = `page.locator('xpath=${xpathParts[0]}')`;

    const cssSelector = id ? `${tag}#${id}` : dataTestId ? `${tag}[data-testid="${dataTestId}"]` : tag;

    return {
      _uid: uid('img'),
      tag,
      text,
      description: el.description || '',
      elRef: null,
      xpath: xpathParts,
      css: cssSelector,
      playwright,
      name: (text || ariaLabel || tag).replace(/\s+/g,'_').replace(/[^A-Za-z0-9_]/g,'').slice(0,40) || 'elem',
      _fromImage: true
    };
  }

  function renderImageResults(elements){
    const list = document.getElementById('imgResultsList');
    if(!list) return;
    list.innerHTML = '';
    elements.forEach((el, i) => {
      const item = document.createElement('div');
      item.className = 'ai-result-item';
      item.innerHTML = `
        <div style="display:flex;align-items:center;gap:6px">
          <input type="checkbox" class="img-elem-check" data-idx="${i}" checked style="margin:0">
          <span class="ai-result-tag">${el.tag || 'elem'}</span>
          <strong style="font-size:13px">${(el.text || el.ariaLabel || el.placeholder || '(no label)').slice(0,60)}</strong>
          ${el.role ? `<span style="font-size:10px;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:4px;padding:1px 5px;color:#166534">${el.role}</span>` : ''}
        </div>
        <div style="color:#6b7280;font-size:11px">${el.description || ''}</div>
        <div style="font-family:ui-monospace,Menlo,monospace;font-size:10px;color:#4338ca;background:#eef2ff;border-radius:4px;padding:3px 6px">${IMG_EXTRACTED[i]?.playwright?.getByRole || IMG_EXTRACTED[i]?.playwright?.getByLabel || IMG_EXTRACTED[i]?.playwright?.getByPlaceholder || '(locator pending)'}</div>
      `;
      list.appendChild(item);
    });
  }

  function addExtractedToLocators(selectedOnly){
    let toAdd = IMG_EXTRACTED;
    if(selectedOnly){
      const checks = document.querySelectorAll('.img-elem-check:checked');
      const idxs = new Set(Array.from(checks).map(c => parseInt(c.dataset.idx)));
      toAdd = IMG_EXTRACTED.filter((_, i) => idxs.has(i));
    }
    if(!toAdd.length){ toast('No elements to add', 'error'); return; }
    NS.CURRENT_LOCATORS = [...NS.CURRENT_LOCATORS, ...toAdd];
    renderLocatorList();
    closeImageExtractor();
    toast(`Added ${toAdd.length} elements from image`, 'success');
  }

  function wireImageExtractor(){
    const btnOpen = document.getElementById('btnOpenImageExtractor');
    if(btnOpen) btnOpen.addEventListener('click', openImageExtractor);

    const btnClose = document.getElementById('btnCloseImageModal');
    if(btnClose) btnClose.addEventListener('click', closeImageExtractor);

    const modal = document.getElementById('imageExtractorModal');
    if(modal) modal.addEventListener('click', (e) => { if(e.target === modal) closeImageExtractor(); });

    const browseLink = document.getElementById('imgBrowseLink');
    const hiddenImg = document.getElementById('hiddenImageFile');
    if(browseLink){
      browseLink.addEventListener('click', () => {
        const lbl = document.getElementById('labelImageFile');
        if(lbl) lbl.click();
      });
    }
    if(hiddenImg){
      hiddenImg.addEventListener('change', async (e) => {
        const file = e.target.files && e.target.files[0];
        if(!file) return;
        const { base64, mimeType } = await fileToBase64(file);
        setImagePreview(base64, mimeType);
        hiddenImg.value = '';
      });
    }

    const dropZone = document.getElementById('imgDropZone');
    if(dropZone){
      dropZone.addEventListener('click', () => { const lbl = document.getElementById('labelImageFile'); if(lbl) lbl.click(); });
      ['dragenter','dragover'].forEach(ev => dropZone.addEventListener(ev, e => { e.preventDefault(); dropZone.classList.add('drag-over'); }));
      ['dragleave','drop'].forEach(ev => dropZone.addEventListener(ev, e => { e.preventDefault(); dropZone.classList.remove('drag-over'); }));
      dropZone.addEventListener('drop', async (e) => {
        const file = e.dataTransfer.files && e.dataTransfer.files[0];
        if(!file || !file.type.startsWith('image/')){ toast('Drop an image file', 'error'); return; }
        const { base64, mimeType } = await fileToBase64(file);
        setImagePreview(base64, mimeType);
      });
    }

    const clearBtn = document.getElementById('imgClearBtn');
    if(clearBtn) clearBtn.addEventListener('click', clearImage);

    const analyzeBtn = document.getElementById('btnAnalyzeImage');
    if(analyzeBtn) analyzeBtn.addEventListener('click', analyzeImage);

    const addAllBtn = document.getElementById('btnAddToLocators');
    if(addAllBtn) addAllBtn.addEventListener('click', () => addExtractedToLocators(false));

    const addSelBtn = document.getElementById('btnAddSelectedToLocators');
    if(addSelBtn) addSelBtn.addEventListener('click', () => addExtractedToLocators(true));
  }

  // ========== ORIGINAL start() — extend to include image extractor wiring ==========

  if(document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', start);
  } else {
    start();
  }
})(window);
</script>
</body>
</html>
