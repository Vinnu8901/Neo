<body>
<div class="app">
  <aside class="side">
    <div class="brand"><span class="beacon"></span> Playwright Studio</div>

    <div class="section">Workspace</div>
    <button class="btn" id="btnPaste">Paste HTML</button>
    <button class="btn" id="btnOpenFile">Open .html file</button>
    <div class="pill">Drag & drop file into preview</div>
    <button class="btn danger" id="btnClear">Clear</button>

    <div class="section">Locator Strategy</div>
    <div class="switch">
      <div class="sw active" data-strategy="accessibility">Accessibility</div>
      <div class="sw" data-strategy="xpath">XPath</div>
      <div class="sw" data-strategy="css">CSS</div>
      <div class="sw" data-strategy="mixed">Mixed</div>
    </div>

    <div style="height:8px"></div>
    <label class="small" style="margin-bottom:4px;display:block;color:var(--dim)">Preferred Method</label>
    <select id="pwMethod" style="width:100%">
      <option value="getByRole">getByRole()</option>
      <option value="getByLabel">getByLabel()</option>
      <option value="getByPlaceholder">getByPlaceholder()</option>
      <option value="getByTestId">getByTestId()</option>
      <option value="getByText">getByText()</option>
      <option value="locator">locator()</option>
    </select>

    <div style="height:8px"></div>
    <button class="btn primary" id="btnGenPlaywright" style="margin-top:8px">Generate Playwright Code</button>
    <button class="btn" id="btnDownloadPlaywright">Download .ts</button>

    <div class="section">Image Extractor <span style="background:linear-gradient(90deg,var(--accent),#5a48f0);color:#fff;font-size:9px;padding:2px 6px;border-radius:999px;vertical-align:middle;margin-left:4px">AI</span></div>
    <button class="btn primary" id="btnOpenImageExtractor">📸 Upload Screenshot</button>
    <div class="small" style="margin-top:2px">Upload any UI screenshot — Claude will identify elements and generate locators automatically.</div>

    <div class="section">Export</div>
    <button class="btn" id="btnExport">Export All</button>
  </aside>

  <main class="main">
    <div class="toolbar">
      <div class="title">Playwright Accessibility Locator Studio</div>
      <div class="hint">Click elements to capture • Accessibility-first approach</div>
    </div>

    <div class="workspace">
      <section class="card">
        <div class="head">Paste HTML & Preview</div>
        <div class="body">
          <textarea class="ed" id="pasteBox" placeholder="Paste full page HTML here..."></textarea>
          <div class="row">
            <button class="btn primary" id="btnRender" style="width:auto">Render Preview</button>
            <div class="pill mono">Click elements to extract locators</div>
          </div>
          <div class="head" style="margin:6px -12px 0;border-radius:10px">Preview</div>
          <div id="dropZone" class="drop">Drop .html here</div>
          <iframe id="preview" sandbox="allow-same-origin allow-forms allow-scripts"></iframe>
        </div>
      </section>

      <section class="card">
        <div class="head">Extracted Locators</div>
        <div class="body" id="rightBody">
          <div class="chip-tabs" id="locatorTabs">
            <div class="chip active" data-paneltab="accessibility">Playwright</div>
            <div class="chip" data-paneltab="xpath">XPath</div>
            <div class="chip" data-paneltab="css">CSS</div>
          </div>

          <div id="locator-toolbar" style="display:flex; gap:10px; align-items:center; flex-wrap:wrap; margin:10px 0;">
            <label><input type="checkbox" id="loc-sel-all"> Select all</label>
            <button id="loc-copy" class="btn" style="padding:6px 10px;width:auto;font-size:12px">Copy selected</button>
            <span id="loc-count" style="margin-left:auto; color:#9db0c5; font-size:13px;"></span>
          </div>

          <div id="locator-list" class="list"></div>

          <div class="head" style="margin:8px -12px 0;border-radius:10px">Code Output</div>
          <textarea class="ed mono" id="output" placeholder="Generated Playwright code will appear here…"></textarea>
        </div>
      </section>
    </div>

    <div class="footer">
      <div class="pill">✨ NEW: Generates getByRole(), getByLabel(), getByTestId() + more</div>
      <div class="pill">Accessibility-first locator strategy</div>
    </div>
  </main>
</div>
<!-- Android-compatible file inputs: use <label> trick instead of .click() -->
<label id="labelHtmlFile" for="hiddenFile" style="display:none"></label>
<input id="hiddenFile" type="file" accept=".html,.htm,.xhtml,.txt" style="position:fixed;left:-9999px;opacity:0;width:1px;height:1px"/>
<label id="labelImageFile" for="hiddenImageFile" style="display:none"></label>
<input id="hiddenImageFile" type="file" accept="image/*" style="position:fixed;left:-9999px;opacity:0;width:1px;height:1px"/>

<!-- Image Extractor Modal -->
<div id="imageExtractorModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:1000;overflow:auto;padding:24px">
  <div style="background:var(--panel);border:1px solid var(--brd);border-radius:18px;max-width:780px;margin:0 auto;overflow:hidden;box-shadow:0 30px 80px rgba(0,0,0,.6)">
    <div style="background:var(--panel2);padding:16px 20px;border-bottom:1px solid var(--brd);display:flex;align-items:center;gap:10px">
      <span style="font-size:18px">📸</span>
      <div style="font-weight:800;font-size:16px">Image Extractor <span style="background:linear-gradient(90deg,var(--accent),#5a48f0);color:#fff;font-size:10px;padding:2px 8px;border-radius:999px;margin-left:6px">AI-Powered</span></div>
      <button id="btnCloseImageModal" style="margin-left:auto;background:none;border:none;color:var(--dim);cursor:pointer;font-size:18px;padding:4px">✕</button>
    </div>

    <div style="padding:20px;display:flex;flex-direction:column;gap:16px">
      <div class="small">Upload a screenshot of any web UI. Claude will analyze the image, identify all interactive elements, and automatically generate XPath, CSS, and Playwright locators.</div>

      <!-- Drop zone / preview -->
      <div id="imgDropZone" class="img-drop-zone">
        <svg width="36" height="36" fill="none" viewBox="0 0 24 24"><path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 20M14 8h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <div style="font-weight:600">Drop screenshot here or <span style="color:var(--accent);text-decoration:underline;cursor:pointer" id="imgBrowseLink">browse</span></div>
        <div style="font-size:11px">PNG, JPG, WEBP supported</div>
      </div>

      <div id="imgPreviewWrap" class="img-preview-wrap hidden">
        <img id="imgPreview" src="" alt="Screenshot preview"/>
        <button id="imgClearBtn" class="img-clear">✕ Remove</button>
      </div>

      <!-- Options -->
      <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center">
        <label class="small">Focus on:</label>
        <label style="font-size:12px;display:flex;gap:4px;align-items:center"><input type="checkbox" id="optButtons" checked> Buttons</label>
        <label style="font-size:12px;display:flex;gap:4px;align-items:center"><input type="checkbox" id="optInputs" checked> Inputs / Forms</label>
        <label style="font-size:12px;display:flex;gap:4px;align-items:center"><input type="checkbox" id="optLinks" checked> Links</label>
        <label style="font-size:12px;display:flex;gap:4px;align-items:center"><input type="checkbox" id="optAll"> All elements</label>
      </div>

      <button class="btn primary" id="btnAnalyzeImage" style="width:auto;align-self:flex-start;padding:10px 24px">🔍 Analyze with Claude AI</button>

      <div id="aiStatus" class="ai-status hidden">
        <div class="dot"></div>
        <span id="aiStatusText">Analyzing image…</span>
      </div>

      <!-- Results -->
      <div id="imgResultsWrap" class="hidden">
        <div class="img-section">Identified Elements</div>
        <div id="imgResultsList" style="display:flex;flex-direction:column;gap:8px;max-height:300px;overflow:auto"></div>
        <div style="margin-top:14px;display:flex;gap:10px">
          <button class="btn primary" id="btnAddToLocators" style="width:auto;padding:10px 20px">➕ Add All to Locator List</button>
          <button class="btn" id="btnAddSelectedToLocators" style="width:auto;padding:10px 20px">Add Selected</button>
        </div>
      </div>
    </div>
  </div>
</div>
<div id="toast" class="toast" aria-live="polite">Ready ✔</div>

<script>
(function(global){
  const NS = (global.PlaywrightStudio = global.PlaywrightStudio || {});
  NS.version = 'playwright-accessibility-2025';
  NS.CURRENT_LOCATORS = [];

  // ========== UTILITY FUNCTIONS ==========
  NS.$ = (sel, root) => { try { return (root||document).querySelector(sel); } catch(e) { return null; } };
  NS.$$ = (sel, root) => { try { return Array.from((root||document).querySelectorAll(sel)); } catch(e){ return []; } };

  function uid(prefix='u'){ return prefix + '_' + Math.random().toString(36).slice(2,10); }

  function toast(msg, type='info'){
    let t = document.getElementById('toast');
    if(!t) return;
    t.textContent = msg;
    t.style.background = type==='error' ? '#b91c1c' : type==='success' ? '#047857' : '#111';
    t.classList.add('show');
    clearTimeout(t._t);
    t._t = setTimeout(()=>{ t.classList.remove('show'); }, 1600);
  }

  async function copyText(txt){
    try {
      await navigator.clipboard.writeText(txt);
      toast('Copied', 'success');
      return true;
    } catch(e){
      try {
        const ta = document.createElement('textarea');
        ta.value = txt;
        ta.style.position = 'fixed';
        ta.style.left = '-9999px';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        ta.remove();
        toast('Copied', 'success');
        return true;
      } catch(err){
        toast('Copy failed', 'error');
        return false;
      }
    }
  }

  // ========== PLAYWRIGHT ACCESSIBILITY LOCATOR GENERATION ==========

  const ROLE_MAP = {
    'button': 'button',
    'a': 'link',
    'input[type="text"]': 'textbox',
    'input[type="password"]': 'textbox',
    'input[type="email"]': 'textbox',
    'input[type="number"]': 'spinbutton',
    'input[type="checkbox"]': 'checkbox',
    'input[type="radio"]': 'radio',
    'select': 'combobox',
    'textarea': 'textbox',
    'input[type="search"]': 'searchbox',
    'h1': 'heading',
    'h2': 'heading',
    'h3': 'heading',
    'h4': 'heading',
    'h5': 'heading',
    'h6': 'heading',
  };

  function inferRole(el){
    try {
      const tag = el.tagName.toLowerCase();
      const type = el.getAttribute('type');
      const role = el.getAttribute('role');
      
      // explicit role takes precedence
      if(role) return role;

      // check ROLE_MAP
      if(type){
        const key = `${tag}[type="${type}"]`;
        if(ROLE_MAP[key]) return ROLE_MAP[key];
      }
      if(ROLE_MAP[tag]) return ROLE_MAP[tag];

      return null;
    } catch(e){ return null; }
  }

  function getAccessibleName(el){
    try {
      // 1. aria-label
      const ariaLabel = el.getAttribute('aria-label');
      if(ariaLabel && ariaLabel.trim()) return ariaLabel.trim();

      // 2. associated label (via for attribute)
      const id = el.id;
      if(id){
        const label = el.ownerDocument.querySelector(`label[for="${id}"]`);
        if(label) return (label.innerText || label.textContent || '').trim();
      }

      // 3
