<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Adhy Automation Studio | Offline + Live</title>
<style>
  :root{
    --bg:#0f1217; --panel:#151a21; --panel2:#171e27; --chip:#202734;
    --txt:#e9eef5; --dim:#9db0c5; --brd:#273243;
    --accent:#7c5cff; --ok:#19c37d; --warn:#ffbf47; --bad:#ff4d4f;
    --ed-bg:#fbfcfe; --ed-brd:#dfe6ee; --ed-txt:#0f172a;
  }
  *{box-sizing:border-box}
  html,body{height:100%}
  body{margin:0;background:var(--bg);color:var(--txt);font-family:Inter,ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto}
  .app{display:grid;grid-template-columns:280px 1fr;height:100%}
  .side{background:linear-gradient(180deg,#0f1217 0,#0f1217 60%,#0b0e13 100%);border-right:1px solid var(--brd);padding:18px 16px;overflow:auto}
  .brand{display:flex;align-items:center;gap:10px;font-weight:800;margin-bottom:14px}
  .beacon{width:10px;height:10px;border-radius:50%;background:linear-gradient(180deg,var(--accent),#563bff);box-shadow:0 0 10px var(--accent)}
  .section{margin:16px 0 8px;color:var(--dim);font-size:12px;letter-spacing:.12em;text-transform:uppercase}
  .btn{width:100%;text-align:left;cursor:pointer;background:var(--panel);border:1px solid var(--brd);border-radius:10px;padding:10px 12px;color:var(--txt);font-weight:600;margin-bottom:8px;transition:.15s}
  .btn:hover{background:var(--panel2);transform:translateY(-1px)}
  .btn.primary{background:linear-gradient(180deg,var(--accent),#6047ff);border-color:#5b49f2}
  .btn.danger{background:linear-gradient(180deg,#ff4d4f,#e13b3e);border-color:#e13b3e}
  .btn.small{padding:6px 10px;width:auto;font-size:12px;display:inline-block}
  .pill{display:flex;gap:8px;align-items:center;background:var(--chip);border:1px solid var(--brd);border-radius:999px;padding:8px 10px;width:max-content;color:var(--dim);font-size:12px}
  .switch{display:flex;gap:8px;flex-wrap:wrap}
  .switch .sw{padding:8px 12px;border:1px solid var(--brd);border-radius:10px;background:var(--panel);cursor:pointer}
  .sw.active{outline:2px solid rgba(124,92,255,.35);background:var(--accent);color:white}
  .main{display:grid;grid-template-rows:auto 1fr auto}
  .toolbar{display:flex;gap:10px;align-items:center;padding:12px 16px;border-bottom:1px solid var(--brd);background:var(--panel);flex-wrap:wrap}
  .toolbar .title{font-weight:800}
  .hint{color:var(--dim);font-size:12px;margin-left:auto}
  .mode-chips{display:flex;gap:8px}
  .mode-chip{padding:6px 10px;border-radius:8px;background:#0f1419;border:1px solid var(--brd);cursor:pointer;color:var(--dim);font-weight:700}
  .mode-chip.active{background:linear-gradient(90deg,var(--accent),#5a48f0);color:#fff}
  .url-bar{flex:1;padding:8px 12px;background:#0f1217;border:1px solid var(--brd);border-radius:8px;color:white;font-family:monospace}
  .workspace{display:grid;grid-template-columns:48% 52%;gap:14px;padding:14px;overflow:auto}
  .card{background:var(--panel);border:1px solid var(--brd);border-radius:14px;overflow:hidden;display:flex;flex-direction:column}
  .card .head{background:var(--panel2);padding:12px 14px;border-bottom:1px solid var(--brd);display:flex;align-items:center;gap:10px;font-weight:700}
  .card .body{padding:12px;display:flex;flex-direction:column;gap:10px}
  textarea.ed{background:var(--ed-bg);border:1px solid var(--ed-brd);border-radius:12px;color:var(--ed-txt);padding:10px;min-height:130px;font-family:monospace}
  iframe#livePreview{width:100%;height:400px;background:#fff;border:none;border-radius:8px}
  .drop{display:flex;justify-content:center;align-items:center;height:56px;border:2px dashed #3a475a;border-radius:12px;color:var(--dim)}
  .chip-tabs{display:flex;gap:8px;flex-wrap:wrap;border-bottom:1px solid var(--brd);padding:8px 12px}
  .chip{padding:8px 12px;border:1px solid var(--brd);border-radius:999px;background:#1a2230;color:#b8c6d9;font-size:12px;cursor:pointer}
  .chip.active{color:#fff;border-color:var(--accent)}
  .list{display:flex;flex-direction:column;gap:6px;max-height:280px;overflow:auto;background:var(--ed-bg);border:1px solid var(--ed-brd);border-radius:12px;padding:8px}
  .element-row{border-radius:8px;padding:8px;margin:8px 0;background:#fff;color:#0f172a;border:1px solid #e6ecf5}
  .step-row{background:var(--panel2);border:1px solid var(--brd);border-radius:8px;padding:8px;margin-bottom:6px;font-size:12px}
  .footer{display:flex;gap:10px;align-items:center;padding:12px 16px;border-top:1px solid var(--brd);background:var(--panel)}
  .toast{position:fixed;bottom:16px;right:16px;background:#131a24;border:1px solid #2a3648;color:#cfe3ff;padding:10px 12px;border-radius:10px;opacity:0;transition:.15s;z-index:9999}
  .toast.show{opacity:1}
  .mono{font-family:monospace}
  .hidden{display:none}
  .recording-indicator{width:12px;height:12px;border-radius:50%;background:#ff4d4f;animation:pulse 1s infinite;display:inline-block;margin-right:8px}
  @keyframes pulse{0%,100%{opacity:1}50%{opacity:0.3}}
</style>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
</head>
<body>
<div class="app">
  <aside class="side">
    <div class="brand"><span class="beacon"></span> Adhy Automation</div>
    <div class="section">Workspace</div>
    <button class="btn" id="btnPasteMode">📄 Paste HTML Mode</button>
    <button class="btn" id="btnLiveMode">🌐 Live Browser Mode</button>
    <button class="btn danger" id="btnClear">Clear All</button>
    
    <div class="section">POM & Steps</div>
    <div class="switch">
      <div class="sw active" data-fw="selenium">Selenium</div>
      <div class="sw" data-fw="playwright">Playwright</div>
    </div>
    <div class="switch">
      <div class="sw active" data-lang="java">Java</div>
      <div class="sw" data-lang="python">Python</div>
      <div class="sw" data-lang="javascript">JavaScript</div>
    </div>
    <button class="btn primary" id="btnGenPOM">Generate POM + Steps</button>
    <button class="btn" id="btnZipAll">Download ZIP</button>
    
    <div class="section">Advanced Locators</div>
    <div class="chip-tabs" id="locatorTabs" style="padding:0;border:none">
      <div class="chip active" data-paneltab="basic">Basic CSS</div>
      <div class="chip" data-paneltab="wildcards">Wildcards</div>
      <div class="chip" data-paneltab="axes">XPath Axes</div>
      <div class="chip" data-paneltab="sf">Salesforce</div>
    </div>
  </aside>

  <main class="main">
    <div class="toolbar">
      <div class="title">Adhy Studio</div>
      <input type="text" id="urlInput" class="url-bar" placeholder="https://example.com" value="https://example.com"/>
      <button id="navigateBtn" class="btn small">🌐 Go</button>
      <button id="recordBtn" class="btn small" style="background:#e5484d">● Record</button>
      <button id="stopBtn" class="btn small">⏹ Stop</button>
      <button id="runBtn" class="btn small">▶ Run</button>
      <button id="extractBtn" class="btn small">🔍 Extract</button>
      <span id="recStatus" class="hint"></span>
    </div>

    <div class="workspace">
      <section class="card">
        <div class="head">Browser Preview</div>
        <div class="body">
          <iframe id="livePreview" src="about:blank"></iframe>
          <div id="pasteArea" class="hidden">
            <textarea id="pasteBox" class="ed" placeholder="Paste HTML here..." rows="8"></textarea>
            <button id="renderHtmlBtn" class="btn primary small">Render HTML</button>
          </div>
        </div>
      </section>

      <section class="card">
        <div class="head">
          <span>Steps & Locators</span>
          <span id="stepCount" class="pill" style="margin-left:auto">0 steps</span>
        </div>
        <div class="body">
          <div id="stepList" style="max-height:200px;overflow:auto;margin-bottom:10px"></div>
          
          <div id="locatorList" class="list" style="max-height:200px"></div>
          
          <textarea id="output" class="ed mono" placeholder="Generated POM / Output..." rows="6" style="min-height:100px"></textarea>
        </div>
      </section>
    </div>
    <div class="footer">
      <div class="pill">Click any locator to copy | Extract from live page | Record actions</div>
    </div>
  </main>
</div>
<div id="toast" class="toast">Ready</div>

<script>
// ==================== ADHY FULL PLATFORM ====================
const Adhy = {
  steps: [],
  isRecording: false,
  locators: [],
  currentMode: 'live', // 'live' or 'paste'
  currentLocatorTab: 'basic',
  
  init() {
    this.bindEvents();
    this.setupIframeBridge();
    this.setupTabSwitching();
    this.setupFrameworkSwitching();
    toast('Adhy Studio Ready');
  },
  
  bindEvents() {
    document.getElementById('navigateBtn')?.addEventListener('click', () => this.navigate());
    document.getElementById('recordBtn')?.addEventListener('click', () => this.startRecording());
    document.getElementById('stopBtn')?.addEventListener('click', () => this.stopRecording());
    document.getElementById('runBtn')?.addEventListener('click', () => this.runSteps());
    document.getElementById('extractBtn')?.addEventListener('click', () => this.extractLocators());
    document.getElementById('btnGenPOM')?.addEventListener('click', () => this.generatePOM());
    document.getElementById('btnZipAll')?.addEventListener('click', () => this.downloadZip());
    document.getElementById('btnClear')?.addEventListener('click', () => this.clearAll());
    document.getElementById('btnPasteMode')?.addEventListener('click', () => this.switchMode('paste'));
    document.getElementById('btnLiveMode')?.addEventListener('click', () => this.switchMode('live'));
    document.getElementById('renderHtmlBtn')?.addEventListener('click', () => this.renderPastedHtml());
  },
  
  setupTabSwitching() {
    const tabs = document.querySelectorAll('#locatorTabs .chip');
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        this.currentLocatorTab = tab.dataset.paneltab;
        this.renderLocators();
      });
    });
  },
  
  setupFrameworkSwitching() {
    // Framework switching
    document.querySelectorAll('.sw[data-fw]').forEach(sw => {
      sw.addEventListener('click', () => {
        document.querySelectorAll('.sw[data-fw]').forEach(s => s.classList.remove('active'));
        sw.classList.add('active');
      });
    });
    
    // Language switching
    document.querySelectorAll('.sw[data-lang]').forEach(sw => {
      sw.addEventListener('click', () => {
        document.querySelectorAll('.sw[data-lang]').forEach(s => s.classList.remove('active'));
        sw.classList.add('active');
      });
    });
  },
  
  setupIframeBridge() {
    // Listen for messages from iframe (for click capture)
    window.addEventListener('message', (event) => {
      if (event.data?.type === 'elementClicked' && this.isRecording) {
        this.captureStep('click', event.data.selector, event.data.text);
      }
    });
  },
  
  async navigate() {
    const url = document.getElementById('urlInput')?.value;
    if (!url) return toast('Enter a URL');
    
    const iframe = document.getElementById('livePreview');
    iframe.src = url;
    toast(`Navigating to ${url}`);
    
    // Wait for load then inject click listener
    iframe.onload = () => {
      this.injectClickCapture(iframe);
      toast('Page loaded - click recording ready');
    };
  },
  
  injectClickCapture(iframe) {
    try {
      const doc = iframe.contentDocument || iframe.contentWindow?.document;
      if (!doc) return;
      
      // Remove old listener if exists
      if (doc._adhyListener) doc.removeEventListener('click', doc._adhyListener);
      
      const handler = (e) => {
        const el = e.target;
        const selector = this.generateSelector(el);
        const text = el.innerText?.slice(0, 50) || el.value || el.tagName;
        window.parent.postMessage({ type: 'elementClicked', selector, text }, '*');
      };
      
      doc.addEventListener('click', handler);
      doc._adhyListener = handler;
      toast('Click capture active');
    } catch(e) {
      console.warn('Cannot inject into cross-origin iframe:', e);
      toast('Cross-origin: Use "Extract" button instead');
    }
  },
  
  generateSelector(el) {
    // Generate selector based on current tab
    if (!el) return '';
    
    switch(this.currentLocatorTab) {
      case 'basic':
        return this.generateBasicSelector(el);
      case 'wildcards':
        return this.generateWildcardSelector(el);
      case 'axes':
        return this.generateXPathAxes(el);
      case 'sf':
        return this.generateSalesforceSelector(el);
      default:
        return this.generateBasicSelector(el);
    }
  },
  
  generateBasicSelector(el) {
    if (el.id) return `#${el.id}`;
    if (el.name) return `[name="${el.name}"]`;
    let selector = el.tagName.toLowerCase();
    if (el.className && typeof el.className === 'string') {
      const cls = el.className.split(' ').filter(c => c).slice(0, 2).join('.');
      if (cls) selector += `.${cls}`;
    }
    return selector;
  },
  
  generateWildcardSelector(el) {
    if (el.id) return `#${el.id}`;
    const text = el.innerText?.trim() || el.value || el.placeholder;
    if (text && text.length < 30) {
      return `//*[contains(text(),'${text.replace(/'/g, "\\'")}')]`;
    }
    return this.generateBasicSelector(el);
  },
  
  generateXPathAxes(el) {
    const parent = el.parentElement;
    if (parent) {
      const parentTag = parent.tagName.toLowerCase();
      const elTag = el.tagName.toLowerCase();
      return `//${parentTag}/descendant::${elTag}`;
    }
    return `//${el.tagName.toLowerCase()}`;
  },
  
  generateSalesforceSelector(el) {
    // Salesforce lightning components often have data-* attributes
    const auraId = el.getAttribute('data-aura-rendered-by');
    const lwcId = el.getAttribute('data-rendered-by');
    
    if (auraId) return `[data-aura-rendered-by="${auraId}"]`;
    if (lwcId) return `[data-rendered-by="${lwcId}"]`;
    if (el.id) return `#${el.id}`;
    
    // Look for lightning specific classes
    const classes = el.className;
    if (classes && typeof classes === 'string') {
      const sfClass = classes.split(' ').find(c => c.startsWith('slds-'));
      if (sfClass) return `.${sfClass}`;
    }
    
    return this.generateBasicSelector(el);
  },
  
  captureStep(action, selector, value) {
    const step = {
      id: Date.now(),
      action,
      selector,
      value: value || '',
      timestamp: new Date().toISOString()
    };
    this.steps.push(step);
    this.renderSteps();
    toast(`Captured: ${action} on ${selector}`);
  },
  
  startRecording() {
    this.isRecording = true;
    document.getElementById('recStatus').innerHTML = '<span class="recording-indicator"></span> RECORDING';
    toast('Recording started - click any element in preview');
  },
  
  stopRecording() {
    this.isRecording = false;
    document.getElementById('recStatus').innerHTML = '';
    toast(`Recording stopped. ${this.steps.length} steps captured`);
  },
  
  async runSteps() {
    if (this.steps.length === 0) return toast('No steps to run');
    
    toast(`Running ${this.steps.length} steps...`);
    const iframe = document.getElementById('livePreview');
    const doc = iframe.contentDocument || iframe.contentWindow?.document;
    
    if (!doc) return toast('No page loaded. Navigate first.');
    
    for (let i = 0; i < this.steps.length; i++) {
      const step = this.steps[i];
      try {
        const el = doc.querySelector(step.selector);
        if (!el) {
          // Try XPath for wildcard/axes selectors
          const xpathResult = document.evaluate(
            step.selector, 
            doc, 
            null, 
            XPathResult.FIRST_ORDERED_NODE_TYPE, 
            null
          );
          const xpathEl = xpathResult.singleNodeValue;
          if (!xpathEl) throw new Error(`Element not found: ${step.selector}`);
          
          if (step.action === 'click') {
            xpathEl.click();
            this.logOutput(`✓ Step ${i+1}: Clicked ${step.selector}`);
          }
        } else {
          if (step.action === 'click') {
            el.click();
            this.logOutput(`✓ Step ${i+1}: Clicked ${step.selector}`);
          } else if (step.action === 'type' && step.value) {
            el.value = step.value;
            el.dispatchEvent(new Event('input', { bubbles: true }));
            this.logOutput(`✓ Step ${i+1}: Typed "${step.value}" into ${step.selector}`);
          }
        }
        await this.sleep(500);
      } catch (err) {
        this.logOutput(`✗ Step ${i+1} failed: ${err.message}`, true);
        toast(`Failed at step ${i+1}`);
        break;
      }
    }
    toast('Execution complete');
  },
  
  async extractLocators() {
    const iframe = document.getElementById('livePreview');
    const doc = iframe.contentDocument || iframe.contentWindow?.document;
    
    if (!doc || !doc.body) {
      // Try paste mode
      const pasteBox = document.getElementById('pasteBox');
      if (pasteBox?.value) {
        return this.extractFromHtml(pasteBox.value);
      }
      return toast('No page loaded. Navigate or paste HTML first.');
    }
    
    this.extractFromDocument(doc);
  },
  
  extractFromDocument(doc) {
    const interactiveSelectors = [
      'input', 'button', 'a', 'select', 'textarea', 
      '[role="button"]', '[onclick]', '[type="submit"]',
      '[data-testid]', '[data-test]', '[data-cy]'
    ];
    
    const elements = doc.querySelectorAll(interactiveSelectors.join(','));
    this.locators = [];
    
    elements.forEach((el, idx) => {
      if (idx > 50) return; // Limit
      
      const selector = this.generateSelector(el);
      const text = el.innerText?.slice(0, 40) || 
                   el.value || 
                   el.placeholder || 
                   el.getAttribute('aria-label') ||
                   el.getAttribute('data-testid') ||
                   el.tagName;
                   
      let name = text.replace(/[^a-zA-Z0-9]/g, '_').slice(0, 30);
      if (!name) name = `element_${idx}`;
      
      this.locators.push({
        id: idx,
        name: name,
        selector: selector,
        tag: el.tagName.toLowerCase(),
        text: text,
        attributes: {
          id: el.id,
          class: el.className,
          dataTestId: el.getAttribute('data-testid')
        }
      });
    });
    
    this.renderLocators();
    toast(`Extracted ${this.locators.length} locators`);
  },
  
  extractFromHtml(html) {
    const parser = new DOMParser();
    const doc = parser.parseFromString(html, 'text/html');
    this.extractFromDocument(doc);
  },
  
  renderSteps() {
    const container = document.getElementById('stepList');
    if (!container) return;
    
    if (this.steps.length === 0) {
      container.innerHTML = '<div style="color:var(--dim);text-align:center;padding:20px">No steps recorded yet</div>';
      document.getElementById('stepCount').innerText = '0 steps';
      return;
    }
    
    container.innerHTML = this.steps.map((step, i) => `
      <div class="step-row">
        <div style="display:flex;justify-content:space-between;align-items:center">
          <div>
            <b>${i+1}.</b> ${step.action} 
            <code style="background:#000;padding:2px 6px;border-radius:4px;margin:0 8px">${step.selector}</code>
            ${step.value ? `<span> → "${step.value}"</span>` : ''}
          </div>
          <div>
            <button class="btn small" style="padding:2px 8px;margin:0" onclick="Adhy.removeStep(${step.id})">✗</button>
          </div>
        </div>
      </div>
    `).join('');
    
    document.getElementById('stepCount').innerText = `${this.steps.length} steps`;
  },
  
  removeStep(id) {
    this.steps = this.steps.filter(s => s.id !== id);
    this.renderSteps();
    toast('Step removed');
  },
  
  renderLocators() {
    const container = document.getElementById('locatorList');
    if (!container) return;
    
    if (this.locators.length === 0) {
      container.innerHTML = '<div style="color:var(--dim);text-align:center;padding:20px">No locators extracted</div>';
      return;
    }
    
    container.innerHTML = this.locators.map(loc => `
      <div class="element-row" style="cursor:pointer" onclick="Adhy.copyToClipboard('${loc.selector.replace(/'/g, "\\'")}')">
        <div style="display:flex;justify-content:space-between;align-items:center">
          <b>${loc.name}</b>
          <span class="pill" style="font-size:10px">${loc.tag}</span>
        </div>
        <code style="font-size:11px;display:block;margin-top:4px">${loc.selector}</code>
        ${loc.text ? `<div style="font-size:11px;color:#64748b;margin-top:4px">${loc.text.substring(0, 50)}</div>` : ''}
      </div>
    `).join('');
  },
  
  generatePOM() {
    const fw = document.querySelector('.sw[data-fw].active')?.dataset.fw || 'selenium';
    const lang = document.querySelector('.sw[data-lang].active')?.dataset.lang || 'java';
    
    if (this.locators.length === 0) {
      return toast('Extract locators first');
    }
    
    const selected = this.locators.slice(0, 15);
    
    let output = '';
    let stepsCode = '';
    
    // Generate POM
    if (fw === 'selenium' && lang === 'java') {
      output = `package com.adhy.pages;\n\n`;
      output += `import org.openqa.selenium.WebDriver;\n`;
      output += `import org.openqa.selenium.WebElement;\n`;
      output += `import org.openqa.selenium.support.FindBy;\n`;
      output += `import org.openqa.selenium.support.PageFactory;\n\n`;
      output += `public class GeneratedPage {\n`;
      output += `    WebDriver driver;\n\n`;
      
      selected.forEach(loc => {
        output += `    @FindBy(css = "${loc.selector}")\n`;
        output += `    private WebElement ${loc.name};\n\n`;
      });
      
      output += `    public GeneratedPage(WebDriver driver) {\n`;
      output += `        this.driver = driver;\n`;
      output += `        PageFactory.initElements(driver, this);\n`;
      output += `    }\n\n`;
      
      // Add methods
      selected.forEach(loc => {
        output += `    public void click${this.capitalize(loc.name)}() {\n`;
        output += `        ${loc.name}.click();\n`;
        output += `    }\n\n`;
      });
      
      output += `}\n`;
      
      // Generate step definitions
      stepsCode = `// Step Definitions\n`;
      stepsCode += `public class StepDefinitions {\n`;
      stepsCode += `    GeneratedPage page;\n\n`;
      stepsCode += `    @Given("I am on the page")\n`;
      stepsCode += `    public void iAmOnThePage() {\n`;
      stepsCode += `        page = new GeneratedPage(driver);\n`;
      stepsCode += `    }\n\n`;
      
      this.steps.forEach((step, i) => {
        stepsCode += `    @When("I perform step ${i+1}")\n`;
        stepsCode += `    public void step${i+1}() {\n`;
        stepsCode += `        // ${step.action} on ${step.selector}\n`;
        stepsCode += `        driver.findElement(By.css("${step.selector}")).click();\n`;
        stepsCode += `    }\n\n`;
      });
      
      stepsCode += `}\n`;
      
    } else if (fw === 'playwright' && lang === 'javascript') {
      output = `// Playwright Page Object\n`;
      output += `const { expect } = require('@playwright/test');\n\n`;
      output += `class GeneratedPage {\n`;
      output += `    constructor(page) {\n`;
      output += `        this.page = page;\n`;
      
      selected.forEach(loc => {
        output += `        this.${loc.name} = page.locator('${loc.selector}');\n`;
      });
      
      output += `    }\n\n`;
      
      selected.forEach(loc => {
        output += `    async click${this.capitalize(loc.name)}() {\n`;
        output += `        await this.${loc.name}.click();\n`;
        output += `    }\n\n`;
      });
      
      output += `}\n\nmodule.exports = { GeneratedPage };\n`;
      
      // Playwright steps
      stepsCode = `// Playwright Test Steps\n`;
      stepsCode += `const { test, expect } = require('@playwright/test');\n`;
      stepsCode += `const { GeneratedPage } = require('./GeneratedPage');\n\n`;
      stepsCode += `test('Adhy Recorded Test', async ({ page }) => {\n`;
      stepsCode += `    const pageObj = new GeneratedPage(page);\n`;
      stepsCode += `    await page.goto('${document.getElementById('urlInput').value}');\n\n`;
      
      this.steps.forEach((step, i) => {
        stepsCode += `    // Step ${i+1}: ${step.action} on ${step.selector}\n`;
        stepsCode += `    await page.locator('${step.selector}').click();\n`;
        stepsCode += `    await page.waitForTimeout(500);\n\n`;
      });
      
      stepsCode += `});\n`;
      
    } else if (lang === 'python') {
      output = `# Python Selenium POM\n`;
      output += `from selenium.webdriver.common.by import By\n`;
      output += `from selenium.webdriver.support.ui import WebDriverWait\n\n`;
      output += `class GeneratedPage:\n`;
      output += `    def __init__(self, driver):\n`;
      output += `        self.driver = driver\n`;
      output += `        self.wait = WebDriverWait(driver, 10)\n\n`;
      
      selected.forEach(loc => {
        output += `    @property\n`;
        output += `    def ${loc.name}(self):\n`;
        output += `        return self.driver.find_element(By.CSS_SELECTOR, "${loc.selector}")\n\n`;
      });
      
      selected.forEach(loc => {
        output += `    def click_${loc.name}(self):\n`;
        output += `        self.${loc.name}.click()\n\n`;
      });
      
    } else {
      output = `# Locators Export\n`;
      output += this.locators.map(l => `${l.name}: "${l.selector}"`).join('\n');
    }
    
    // Combine POM and Steps
    const finalOutput = output + (stepsCode ? '\n\n' + stepsCode : '');
    document.getElementById('output').value = finalOutput;
    toast('POM + Steps generated');
  },
  
  capitalize(str) {
    return str.charAt(0).toUpperCase() + str.slice(1);
  },
  
  downloadZip() {
    const content = document.getElementById('output').value;
    if (!content) return toast('Generate POM first');
    
    const fw = document.querySelector('.sw[data-fw].active')?.dataset.fw || 'selenium';
    const lang = document.querySelector('.sw[data-lang].active')?.dataset.lang || 'java';
    
    let filename = 'adhy-page-object';
    let extension = '.txt';
    
    if (fw === 'selenium' && lang === 'java') extension = '.java';
    else if (fw === 'playwright' && lang === 'javascript') extension = '.js';
    else if (lang === 'python') extension = '.py';
    
    const blob = new Blob([content], { type: 'text/plain' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = filename + extension;
    a.click();
    URL.revokeObjectURL(a.href);
    toast(`Downloaded ${filename}${extension}`);
  },
  
  switchMode(mode) {
    this.currentMode = mode;
    const pasteArea = document.getElementById('pasteArea');
    const iframe = document.getElementById('livePreview');
    const btnPaste = document.getElementById('btnPasteMode');
    const btnLive = document.getElementById('btnLiveMode');
    
    if (mode === 'paste') {
      pasteArea?.classList.remove('hidden');
      iframe.classList.add('hidden');
      btnPaste.style.background = 'var(--accent)';
      btnLive.style.background = 'var(--panel)';
      toast('Paste HTML mode - paste your HTML and click Render');
    } else {
      pasteArea?.classList.add('hidden');
      iframe.classList.remove('hidden');
      btnLive.style.background = 'var(--accent)';
      btnPaste.style.background = 'var(--panel)';
      toast('Live mode - enter URL and click Go');
    }
  },
  
  renderPastedHtml() {
    const html = document.getElementById('pasteBox')?.value;
    if (!html) return toast('Paste HTML first');
    
    const iframe = document.getElementById('livePreview');
    iframe.classList.remove('hidden');
    document.getElementById('pasteArea')?.classList.add('hidden');
    iframe.srcdoc = html;
    
    // Update mode buttons
    document.getElementById('btnLiveMode').style.background = 'var(--accent)';
    document.getElementById('btnPasteMode').style.background = 'var(--panel)';
    this.currentMode = 'live';
    
    toast('HTML rendered');
    setTimeout(() => this.extractFromHtml(html), 500);
  },
  
  clearAll() {
    if (confirm('Clear all steps and locators?')) {
      this.steps = [];
      this.locators = [];
      this.renderSteps();
      this.renderLocators();
      document.getElementById('output').value = '';
      document.getElementById('pasteBox').value = '';
      document.getElementById('recStatus').innerHTML = '';
      this.isRecording = false;
      toast('All cleared');
    }
  },
  
  logOutput(msg, isError = false) {
    const output = document.getElementById('output');
    const timestamp = new Date().toLocaleTimeString();
    output.value += `\n[${timestamp}] ${isError ? '❌' : '✅'} ${msg}`;
    output.scrollTop = output.scrollHeight;
  },
  
  copyToClipboard(text) {
    navigator.clipboard?.writeText(text).then(() => {
      toast(`Copied: ${text}`);
    }).catch(() => {
      // Fallback
      const textarea = document.createElement('textarea');
      textarea.value = text;
      document.body.appendChild(textarea);
      textarea.select();
      document.execCommand('copy');
      document.body.removeChild(textarea);
      toast(`Copied: ${text}`);
    });
  },
  
  sleep(ms) { 
    return new Promise(resolve => setTimeout(resolve, ms)); 
  }
};

function toast(msg) {
  const t = document.getElementById('toast');
  if (!t) return;
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2000);
}

// Start
document.addEventListener('DOMContentLoaded', () => Adhy.init());
window.Adhy = Adhy;
</script>
